#!/bin/sh

set -e

usage() {
    echo "Usage: ./configure [options]"
    echo "  --with-debug    enable debug mode (-g3 -O0 -DDEBUG)"
    echo "  --with-qemu     build for QEMU (generic SDHCI, RGB pixel order)"
    echo "  --help          show this help"
}

debug=0
qemu=0

for arg in "$@"; do
    case "$arg" in
        --with-debug) debug=1 ;;
        --with-qemu)  qemu=1 ;;
        --help)       usage; exit 0 ;;
        *)            echo "Unknown option: $arg"; usage; exit 1 ;;
    esac
done

> makefile.rules
if [ "$debug" = 1 ]; then echo "CFLAGS+=-g3 -O0 -DDEBUG" >> makefile.rules; fi
if [ "$qemu" = 1 ]; then echo "CFLAGS+=-DQEMU" >> makefile.rules; fi
